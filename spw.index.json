{
  "schema": "spw-index/v1",
  "version": "2026-02-28",
  "project": {
    "name": "spwashi.click",
    "type": "static-web-language-site",
    "north_star": "seed/extern/spw-workbench"
  },
  "cross_repo": {
    "downstream_reference": {
      "repo": "https://github.com/spwashi/spwashi.work",
      "relation": "reference-not-mirror",
      "entrypoints": [
        "spw.index.json",
        "spw.index.spw",
        ".spw/workspace.spw"
      ],
      "policy": "Downstream repos reference contracts and semantics from this repo without sharing git history."
    }
  },
  "entrypoints": {
    "spw": "spw.index.spw",
    "workspace": ".spw/workspace.spw",
    "runtime_module": "src/runtime/index.js",
    "runtime_boot": "src/core/runtime/js/boot.js",
    "runtime_control": "src/core/runtime/js/runtime-control.js",
    "runtime_config": "src/core/runtime/js/runtime-config.js",
    "pwa_runtime": "src/core/runtime/js/pwa.js",
    "pwa_manifest": "manifest.webmanifest",
    "service_worker": "sw.js",
    "assets_manifest": "assets.manifest.json",
    "assets_export_script": "scripts/export-assets.js",
    "feature_copy": "src/content/manifests.js"
  },
  "semantics": {
    "phases": [
      {
        "name": "seed",
        "click_range": "0-2",
        "spw": "^phase[seed]{ model:geometry-init learn:click=>state }"
      },
      {
        "name": "pulse",
        "click_range": "3-7",
        "spw": "^phase[pulse]{ model:motion-entry learn:state=>tempo }"
      },
      {
        "name": "counterpoint",
        "click_range": "8-15",
        "spw": "^phase[counterpoint]{ model:fragment-weave learn:relation=>meaning }"
      },
      {
        "name": "chorus",
        "click_range": "16+",
        "spw": "^phase[chorus]{ model:full-combinatorics learn:system=>presence }"
      }
    ],
    "braces": {
      "{}": {
        "layout_view": "flow",
        "nav_step": 0
      },
      "[]": {
        "layout_view": "grid",
        "nav_step": 2
      },
      "()": {
        "layout_view": "focus",
        "nav_step": -1
      },
      "<>": {
        "layout_view": "stack",
        "nav_step": 1
      }
    },
    "operators": {
      "?": "probe / wonder",
      "~": "potential / defer",
      "@": "perspective / observer",
      "&": "confluence / merge",
      "*": "value / collapse",
      "^": "integration / framing",
      "!": "action / injection",
      "=": "constraint / bias",
      "%": "measure / scalar",
      "#": "annotation / resonance",
      ".": "ground / access"
    },
    "runtime_command_surface": {
      "forms": [
        "!top{ route:work clicks:9 profile:maximal llm:true }",
        "!region{ selector:.chapter-panel attr.data-state:active text:\"^panel{ tuned }\" }",
        "!component{ selector:spw-syntax-lab style.--facet-glow:1.1 }",
        "!vars{ --fx-drift-x:12 --fx-drift-y:-8 }",
        "!reset{ route:home profile:field }",
        "!rebind{}",
        "!catalog{ summary:true }"
      ],
      "source": [
        "src/core/runtime/js/spw-command-surface.js",
        "src/core/runtime/js/runtime-control.js"
      ]
    },
    "pwa_state": {
      "states": [
        "unsupported",
        "registering",
        "ready",
        "update-ready",
        "updating",
        "error"
      ],
      "source": [
        "src/core/runtime/js/pwa.js",
        "src/core/runtime/js/events.js"
      ]
    },
    "embed_modes": {
      "modes": [
        "standalone",
        "embedded",
        "assets-only"
      ],
      "meta_controls": [
        "spw:embed-mode",
        "spw:base-url",
        "spw:sw-enabled",
        "spw:auto-mount"
      ],
      "source": [
        "src/core/runtime/js/runtime-config.js",
        "src/core/runtime/js/runtime.js",
        "src/runtime/index.js"
      ]
    },
    "medium_flow": {
      "map": "facet-cadence + auto-phase + language-console",
      "source": [
        "src/core/runtime/js/medium-flow.js",
        "src/styles/components.css"
      ]
    }
  },
  "contracts": {
    "store_shape": {
      "clickCount": "number",
      "phase": "seed|pulse|counterpoint|chorus",
      "unlockedLayers": "string[]",
      "reducedMotion": "boolean",
      "activeRoute": "home|work|notes",
      "lastClickSource": "string"
    },
    "events": [
      "spw:intent:click",
      "spw:state:changed",
      "spw:phase:changed",
      "spw:navigate",
      "spw:app:ready",
      "spw:ecology:changed",
      "spw:enhancement:loaded",
      "spw:enhancement:failed",
      "spw:pwa:state-changed"
    ],
    "runtime_methods": [
      "getSnapshot",
      "getCatalog",
      "setTopLevel",
      "setRegion",
      "setComponent",
      "setWindowVars",
      "resetRuntime",
      "rebindRuntime",
      "evalSpw",
      "run"
    ]
  },
  "features": [
    {
      "id": "click-stage",
      "route": "/",
      "spw": "^feature[click-stage]{ input:click|enter|space|arrow-right output:phase+lumen+layers }",
      "files": [
        "src/components/click-stage.js",
        "src/core/runtime/js/store.js",
        "src/core/runtime/js/motion.js",
        "src/styles/components.css"
      ]
    },
    {
      "id": "shader-field",
      "route": "/",
      "spw": "^feature[shader-field]{ input:pointer+keyboard output:harmonics+intent-click profile-aware:true }",
      "files": [
        "src/components/shader-field.js",
        "src/core/runtime/js/space-metrics.js",
        "src/styles/components.css"
      ]
    },
    {
      "id": "syntax-lab",
      "route": "/",
      "spw": "^feature[syntax-lab]{ braces:layout-view operators:component-view nodes:facet-nav }",
      "files": [
        "src/components/syntax-lab.js",
        "src/core/runtime/js/spwlang-parser.js",
        "src/styles/components.css",
        "src/styles/layout.css"
      ]
    },
    {
      "id": "seed-atlas-enhancement",
      "route": "/,/notes/",
      "spw": "^feature[seed-atlas]{ source:seed-manifest behavior:thumb+keyboard+phase-lighting }",
      "files": [
        "seed/site/enhancements/seed-atlas.js",
        "src/core/runtime/js/iterative-enhancement.js",
        "seed/site/enhancements.manifest.json"
      ]
    },
    {
      "id": "runtime-control",
      "route": "global",
      "spw": "^feature[runtime-control]{ target:llm methods:evalSpw+setTopLevel+setRegion+rebind }",
      "files": [
        "src/core/runtime/js/runtime-control.js",
        "src/core/runtime/js/spw-command-surface.js",
        "src/core/runtime/js/boot.js"
      ]
    },
    {
      "id": "structure-mode",
      "route": "global",
      "spw": "^feature[structure-mode]{ toggle:data-llm-readable-structure projection:aria-description }",
      "files": [
        "src/core/runtime/js/structure-mode.js",
        "src/components/syntax-lab.js",
        "src/styles/components.css"
      ]
    },
    {
      "id": "medium-flow",
      "route": "global",
      "spw": "^feature[medium-flow]{ cadence:autoplay facets:layout-region controls:arrow+space+home }",
      "files": [
        "src/core/runtime/js/medium-flow.js",
        "src/core/runtime/js/runtime.js",
        "src/styles/components.css"
      ]
    },
    {
      "id": "modular-runtime-package",
      "route": "global",
      "spw": "^feature[package]{ entry:src/runtime/index.js modes:standalone|embedded|assets-only assets:manifest+export-script }",
      "files": [
        "src/core/runtime/js/runtime.js",
        "src/core/runtime/js/runtime-config.js",
        "src/runtime/index.js",
        "assets.manifest.json",
        "scripts/export-assets.js",
        "docs/embed-package.md"
      ]
    },
    {
      "id": "performance-tuning",
      "route": "global",
      "spw": "^feature[performance]{ profiles:seed|field|maximal source:tealstripesvibes }",
      "files": [
        "src/core/runtime/js/performance-tuning.js",
        "src/styles/tokens.css",
        "src/styles/components.css"
      ]
    },
    {
      "id": "pwa-support",
      "route": "global",
      "spw": "^feature[pwa]{ install:manifest+sw state:online|offline|ready release-cache:date-arc-vibe }",
      "files": [
        "src/core/runtime/js/pwa.js",
        "manifest.webmanifest",
        "sw.js",
        "scripts/build-static.js"
      ]
    }
  ],
  "tooling_care": {
    "lsp": {
      "entry": "seed/extern/spw-workbench/scripts/lsp/stdio-server.ts",
      "index": "seed/extern/spw-workbench/scripts/lsp/server-index.ts",
      "smoke": "seed/extern/spw-workbench/scripts/lsp/smoke-navigation.ts",
      "editor_integration_doc": "seed/extern/spw-workbench/docs/runtime/md/lsp-editor-integration.md"
    },
    "neovim": {
      "plugin": "seed/extern/spw-workbench/extensions/neovim-spw",
      "lsp_client": "seed/extern/spw-workbench/extensions/neovim-spw/lua/spw-lsp.lua",
      "readme": "seed/extern/spw-workbench/extensions/neovim-spw/README.md"
    },
    "vscode": {
      "extension": "seed/extern/spw-workbench/extensions/vscode-spw/src/extension.ts",
      "semantics_table": "seed/extern/spw-workbench/extensions/vscode-spw/src/semantics.ts",
      "root_map": "seed/extern/spw-workbench/extensions/vscode-spw/src/roots.ts",
      "concept_tree": "seed/extern/spw-workbench/extensions/vscode-spw/src/views/concepts-tree.ts"
    },
    "intellij": {
      "lsp_provider": "seed/extern/spw-workbench/extensions/intellij-spw/src/main/kotlin/com/spwashi/spw/SpwLspServerSupportProvider.kt",
      "readme": "seed/extern/spw-workbench/extensions/intellij-spw/README.md"
    },
    "history": [
      "seed/extern/spw-workbench/docs/design/md/history.md",
      "seed/extern/spw-workbench/docs/archive/status/md/vim-implementation-complete.md",
      "seed/extern/spw-workbench/docs/audits/md/vim-keybindings-inconsistencies-audit.md"
    ]
  },
  "crawl_protocol": {
    "order": [
      "spw.index.json",
      "spw.index.spw",
      ".spw/workspace.spw",
      "src/core/runtime/js/boot.js",
      "src/core/runtime/js/runtime-control.js",
      "src/core/runtime/js/pwa.js",
      "manifest.webmanifest",
      "sw.js",
      "assets.manifest.json",
      "src/content/manifests.js",
      "docs/component-ecology.md",
      "docs/embed-package.md"
    ],
    "feature_question_template": "!ask[feature-gap]{ compare:features wanted:project-goals output:add-next-feature-list }"
  }
}
