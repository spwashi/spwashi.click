    "modes": [
      "standalone",
      "embedded",
      "assets-only"
    ]
  },
  "styles": [
    "/src/styles/tokens.css?v=__ASSET_VERSION__",
    "/src/styles/base.css?v=__ASSET_VERSION__",
    "/src/styles/layout.css?v=__ASSET_VERSION__",
    "/src/styles/components.css?v=__ASSET_VERSION__"
  ],
  "contracts": [
    "/spw.index.json",
    "/spw.index.spw",
    "/.spw/workspace.spw"
  ],
  "assets": [
    "/favicon.svg",
    "/manifest.webmanifest?v=__ASSET_VERSION__",
    "/sw.js?v=__ASSET_VERSION__"
  ],
  "optional": [
    "/seed/site/enhancements.manifest.json?v=__ASSET_VERSION__",
    "/seed/images/"
  ]
}

