{
  "schema": "spw-assets/v1",
  "assetVersion": "__ASSET_VERSION__",
  "release": {
    "date": "__RELEASE_DATE__",
    "id": "__RELEASE_ID__",
    "arc": "__RELEASE_ARC__",
    "vibe": "__RELEASE_VIBE__"
  },
  "runtime": {
    "module": "/src/runtime/index.js?v=__ASSET_VERSION__",
    "boot": "/src/core/boot.js?v=__ASSET_VERSION__",
    "config_meta": [
      "spw:embed-mode",
      "spw:base-url",
      "spw:sw-enabled",
      "spw:auto-mount"
