~#module{
  @source: ~"../js/events.js"
  @path: ~"src/core/runtime/js/events.js"

  ^scan{
    @id: core.events
    @axis: typed-event-contracts
    @output: explicit-runtime-signals
    @hotspots: events.js
  }

  ^intent[module]{ id:core.events axis:typed-event-contracts output:explicit-runtime-signals }

  ^prefix-utility{
    !:: role:dispatch event:CustomEvent detail:frozen includes:workbench-parser+runtime-rebind+host-manifest+theme+gating+register+viewport
    @:: role:subscribe event:known-contract returns:unsubscribe
    =:: role:registry anchor:KNOWN_EVENT_NAMES
  }

  ^postfix-utility{
    state~{ read:store+components+controllers }
    view!{ write:state|phase|navigate|pwa|workbench|host events }
    bind@{ bridge:runtime-control+crawler-tools+parser-observability+host-extensions }
  }

  ^operator-overload{
    !{ role:dispatch event:CustomEvent detail:frozen includes:workbench-parser+runtime-rebind+host-manifest+theme+gating+register+viewport }
    @{ role:subscribe event:known-contract returns:unsubscribe }
    ={ role:registry anchor:KNOWN_EVENT_NAMES }
  }

  ^state-embed{
    @reads: store+components+controllers
    @writes: state|phase|navigate|pwa|workbench|host events
    @bridge: runtime-control+crawler-tools+parser-observability+host-extensions
    @shape: deterministic-projection
  }

  ^macro-embed{
    ^macro[core_events_scan]{
      input: prefix+state
      flow: read->map(typed-event-contracts)->project
      output: explicit-runtime-signals
    }
    ^macro[core_events_patch]{
      input: delta+intent
      flow: validate->apply->emit
      output: state|phase|navigate|pwa events
    }
  }

  ^invariants{
    ^invariant[registry]{ runtime-events declared:once }
    ^invariant[payload]{ detail:frozen shape:serializable-first }
    ^invariant[transport]{ window|element dispatch parity:true runtime-rebind typed:true }
    ^invariant[host]{ host-manifest+theme+gating events included in-registry }
    ^invariant[register]{ register-bank activity emits:spw:register:changed }
    ^invariant[viewport]{ responsive transitions emit:spw:viewport:changed }
  }

  ^potential{
    ^potential[contract-doc]{ generate:machine-readable-event-spec }
    ^potential[trace]{ layer:event-graph replay-for-debug+workbench-bridge+host-overlays }
  }

  ^compose[neighbors]{ ingress:store+components+controllers egress:state|phase|navigate|pwa|workbench|host events bridge:runtime-control+crawler-tools+parser-observability+host-extensions }
}
