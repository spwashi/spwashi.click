~#module{
  @source: ~"../../js/structure/mode.js"
  @path: ~"src/core/runtime/js/structure/mode.js"

  ^scan{
    @id: core.structure.mode
    @axis: llm-readable-aria-overlay
    @output: quiet-structural-legibility
    @hotspots: structure/mode.js
  }

  ^intent[module]{ id:core.structure.mode axis:llm-readable-aria-overlay output:quiet-structural-legibility }

  ^prefix-utility{
    !:: role:toggle-structure mode:on|off
    @:: role:annotate nodes:data-structure-label->aria-description
    ~:: role:persist-preference localstorage:optional
  }

  ^postfix-utility{
    state~{ read:toggle-ui+runtime-control }
    view!{ write:aria-description+dataset flags }
    bind@{ bridge:components+llm-agents }
  }

  ^operator-overload{
    !{ role:toggle-structure mode:on|off }
    @{ role:annotate nodes:data-structure-label->aria-description }
    ~{ role:persist-preference localstorage:optional }
  }

  ^state-embed{
    @reads: toggle-ui+runtime-control
    @writes: aria-description+dataset flags
    @bridge: components+llm-agents
    @shape: deterministic-projection
  }

  ^macro-embed{
    ^macro[core_structure_mode_scan]{
      input: prefix+state
      flow: read->map(llm-readable-aria-overlay)->project
      output: quiet-structural-legibility
    }
    ^macro[core_structure_mode_patch]{
      input: delta+intent
      flow: validate->apply->emit
      output: aria-description+dataset flags
    }
  }

  ^invariants{
    ^invariant[opt-in]{ only:data-structure-label nodes annotated }
    ^invariant[noise]{ visual-layout unchanged }
    ^invariant[persistence]{ query/localstorage override precedence:explicit }
  }

  ^potential{
    ^potential[crawler-mode]{ richer machine labels gated-by:toggle }
    ^potential[semantic-layers]{ route-specific structure vocabularies }
  }

  ^compose[neighbors]{ ingress:toggle-ui+runtime-control egress:aria-description+dataset flags bridge:components+llm-agents }
}
