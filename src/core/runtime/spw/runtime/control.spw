~#module{
  @source: ~"../../js/runtime/control.js"
  @path: ~"src/core/runtime/js/runtime/control.js"

  ^scan{
    @id: core.runtime.control
    @axis: llm-manipulation
    @output: bounded-runtime-api
    @hotspots: runtime/control.js
  }

  ^intent[module]{ id:core.runtime.control axis:llm-manipulation output:bounded-runtime-api }

  ^prefix-utility{
    !:: role:setTopLevel route|clicks|profile|structure
    @:: role:setRegion|setComponent selector-scoped
    ~:: role:setWindowVars css-var projection
    =:: role:getIntegrationStatus parser-bridge+embed+host+viewport snapshot
    %:: role:api-contract contract+interfaces+compose+register-bank
    ^:: role:ecology-extension register-species+note-lifecycle
    &:: role:setViewportMode adaptive|fixed + band/mobile projection
    $:: role:register-bank focus+set+extract+deposit+mark+promote+demote+couple+measure
    ?:: role:getHostManifest host-overlay payload
  }

  ^postfix-utility{
    state~{ read:runtime-app+catalog }
    view!{ write:window.__SPW_RUNTIME__ }
    bind@{ bridge:spw-command-surface+typed-runtime-rebind-event }
  }

  ^operator-overload{
    !{ role:setTopLevel route|clicks|profile|structure }
    @{ role:setRegion|setComponent selector-scoped }
    ~{ role:setWindowVars css-var projection }
    ={ role:getIntegrationStatus parser-bridge+embed+host+viewport snapshot }
    %{ role:api-contract contract+interfaces+compose+register-bank }
    ^{ role:ecology-extension register-species+note-lifecycle }
    &{ role:setViewportMode adaptive|fixed + band/mobile projection }
    ${ role:register-bank focus+set+extract+deposit+mark+promote+demote+couple+measure }
    ?{ role:getHostManifest host-overlay payload }
  }

  ^state-embed{
    @reads: runtime-app+catalog
    @writes: window.__SPW_RUNTIME__
    @bridge: spw-command-surface+typed-runtime-rebind-event+integration-status+ecology-extension+register-bank+viewport
    @shape: deterministic-projection
  }

  ^macro-embed{
    ^macro[core_runtime_control_scan]{
      input: prefix+state
      flow: read->map(llm-manipulation)->project
      output: bounded-runtime-api
    }
    ^macro[core_runtime_control_patch]{
      input: delta+intent
      flow: validate->apply->emit
      output: window.__SPW_RUNTIME__
    }
  }

  ^invariants{
    ^invariant[mutation]{ selector-bounded all:false-default snapshot:returned }
    ^invariant[state]{ top-level updates route-through-store reason:tagged }
    ^invariant[reset]{ reset-runtime clears-clicks+fx-vars keeps-contract-surface }
    ^invariant[events]{ runtime-rebind emits:spw:runtime:rebind detail:route }
    ^invariant[integration]{ status reports parser-bridge+embed+host+viewport settings }
    ^invariant[contract]{ api-version+interfaces projection stable }
    ^invariant[register-bank]{ focus-register always-defined couplings:bidirectional liminality:0..3 measure-depth:non-negative }
    ^invariant[viewport]{ mode+band+mobile mirrored to dataset and event:spw:viewport:changed }
  }

  ^potential{
    ^potential[macro]{ compose:Spw command macros for live-direction }
    ^potential[safety]{ policy-layer around selectors+vars }
  }

  ^compose[neighbors]{ ingress:runtime-app+catalog egress:window.__SPW_RUNTIME__ bridge:spw-command-surface+typed-runtime-rebind-event+integration-status+ecology-extension+register-bank+viewport }
}
