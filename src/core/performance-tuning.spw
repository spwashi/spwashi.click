~#module{
  @source: ~"./performance-tuning.js"
  @path: ~"src/core/performance-tuning.js"

  ^scan{
    @id: core.performance-tuning
    @axis: profile-controller
    @output: tunable-fx-budget
    @hotspots: performance-tuning.js
  }

  ^intent[module]{ id:core.performance-tuning axis:profile-controller output:tunable-fx-budget }

  ^prefix-utility{
    !:: role:apply-profile target:css-vars+datasets
    @:: role:cycle-profile source:ui-toggle|runtime-api
    ~:: role:merge-remote-tuner source:tealstripesvibes
  }

  ^postfix-utility{
    state~{ read:release+meta+runtime-control }
    view!{ write:data-performance-profile+css-vars }
    bind@{ bridge:styles+shader+medium-flow }
  }

  ^operator-overload{
    !{ role:apply-profile target:css-vars+datasets }
    @{ role:cycle-profile source:ui-toggle|runtime-api }
    ~{ role:merge-remote-tuner source:tealstripesvibes }
  }

  ^state-embed{
    @reads: release+meta+runtime-control
    @writes: data-performance-profile+css-vars
    @bridge: styles+shader+medium-flow
    @shape: deterministic-projection
  }

  ^macro-embed{
    ^macro[core_performance_tuning_scan]{
      input: prefix+state
      flow: read->map(profile-controller)->project
      output: tunable-fx-budget
    }
    ^macro[core_performance_tuning_patch]{
      input: delta+intent
      flow: validate->apply->emit
      output: data-performance-profile+css-vars
    }
  }

  ^invariants{
    ^invariant[profiles]{ seed|field|maximal domain:closed }
    ^invariant[persistence]{ profile:localstorage optional:true }
    ^invariant[safety]{ remote-tuner parse-fail => defaults-keep }
  }

  ^potential{
    ^potential[adaptive]{ profile:auto from:device+fps }
    ^potential[llm-control]{ route:setWindowVars+setTopLevel perf orchestration }
  }

  ^compose[neighbors]{ ingress:release+meta+runtime-control egress:data-performance-profile+css-vars bridge:styles+shader+medium-flow }
}
