# Spw Source Index
#
# Public crawler-oriented Spw surface for feature discovery.

#>spwashi_click_source_index
#:index #!crawler

^"intent"{
  ~#goal: "Give source crawlers a stable, executable map of what exists now."
  ~#mode: "feature-inventory + semantics + tooling-care"
}

^reference[spwashi-work]{
  repo: "https://github.com/spwashi/spwashi.work"
  relation: "downstream-reference"
  contract: "spwashi.work references this repository by index and workspace contracts without mirroring source."
  entrypoints: [spw.index.json, spw.index.spw, .spw/index.spw, .spw/workspace.spw, .spw/surfaces/plugin-protocol.spw]
}

^feature[click-stage]{
  route: "/"
  contract: "^feature[click-stage]{ input:click|enter|space|arrow-right output:phase+lumen+layers }"
  files: [src/components/click-stage.js, src/core/runtime/js/store.js, src/core/runtime/js/motion.js]
}

^feature[shader-field]{
  route: "/"
  contract: "^feature[shader-field]{ input:pointer+keyboard output:harmonics+intent-click profile-aware:true }"
  files: [src/components/shader-field.js, src/core/runtime/js/space-metrics.js, src/styles/components.css]
}

^feature[syntax-lab]{
  route: "/"
  contract: "^feature[syntax-lab]{ braces:layout-view operators:component-view nodes:facet-nav }"
  files: [src/components/syntax-lab.js, src/core/runtime/js/spwlang-parser.js]
}

^feature[seed-atlas]{
  route: "/,/notes/"
  contract: "^feature[seed-atlas]{ source:seed-manifest behavior:thumb+keyboard+phase-lighting }"
  files: [seed/site/enhancements/seed-atlas.js, src/core/runtime/js/iterative-enhancement.js]
}

^feature[runtime-control]{
  route: "global"
  contract: "^feature[runtime-control]{ target:llm methods:evalSpw+setTopLevel+setRegion+rebind }"
  files: [src/core/runtime/js/runtime-control.js, src/core/runtime/js/spw-command-surface.js, src/core/runtime/js/boot.js]
}

^feature[structure-mode]{
  route: "global"
  contract: "^feature[structure-mode]{ toggle:data-llm-readable-structure projection:aria-description }"
  files: [src/core/runtime/js/structure-mode.js, src/components/syntax-lab.js]
}

^feature[performance]{
  route: "global"
  contract: "^feature[performance]{ profiles:seed|field|maximal source:tealstripesvibes }"
  files: [src/core/runtime/js/performance-tuning.js, src/styles/tokens.css]
}

^feature[pwa]{
  route: "global"
  contract: "^feature[pwa]{ install:manifest+sw state:online|offline|ready release-cache:date-arc-vibe }"
  files: [src/core/runtime/js/pwa.js, manifest.webmanifest, sw.js, scripts/build-static.js]
}

^feature[medium-flow]{
  route: "global"
  contract: "^feature[medium-flow]{ cadence:autoplay facets:layout-region controls:arrow+space+home }"
  files: [src/core/runtime/js/medium-flow.js, src/core/runtime/js/runtime.js, src/styles/components.css]
}

^feature[modular-package]{
  route: "global"
  contract: "^feature[package]{ entry:src/runtime/index.js modes:standalone|embedded|assets-only assets:manifest+export-script }"
  files: [src/core/runtime/js/runtime.js, src/core/runtime/js/runtime-config.js, src/runtime/index.js, assets.manifest.json, scripts/export-assets.js, docs/embed-package.md]
}

^semantics[operators]{
  chain: "? ~ @ & * ^ ! = % # ."
  source: [src/components/syntax-lab.js, seed/extern/spw-workbench/extensions/vscode-spw/src/semantics.ts]
}

^semantics[braces]{
  map: "{ } -> flow, [ ] -> grid, ( ) -> focus, < > -> stack"
  source: [src/components/syntax-lab.js]
}

^semantics[phases]{
  map: "seed(0-2), pulse(3-7), counterpoint(8-15), chorus(16+)"
  source: [src/core/runtime/js/motion.js, src/components/click-stage.js]
}

^semantics[runtime-command]{
  forms: "!top{} !region{} !component{} !vars{} !reset{} !rebind{} !catalog{}"
  source: [src/core/runtime/js/spw-command-surface.js, src/core/runtime/js/runtime-control.js]
}

^semantics[pwa-state]{
  map: "unsupported, registering, ready, update-ready, updating, error"
  source: [src/core/runtime/js/pwa.js, src/core/runtime/js/events.js]
}

^semantics[embed-modes]{
  map: "standalone, embedded, assets-only"
  controls: "spw:embed-mode spw:base-url spw:sw-enabled spw:auto-mount"
  source: [src/core/runtime/js/runtime-config.js, src/core/runtime/js/runtime.js, src/runtime/index.js]
}

^semantics[medium-flow]{
  map: "facet-cadence + auto-phase + language-console"
  source: [src/core/runtime/js/medium-flow.js, src/styles/components.css]
}

^care[lsp]{
  entry: seed/extern/spw-workbench/scripts/lsp/stdio-server.ts
  index: seed/extern/spw-workbench/scripts/lsp/server-index.ts
  smoke: seed/extern/spw-workbench/scripts/lsp/smoke-navigation.ts
}

^care[neovim]{
  plugin: seed/extern/spw-workbench/extensions/neovim-spw
  lsp_client: seed/extern/spw-workbench/extensions/neovim-spw/lua/spw-lsp.lua
}

^care[vscode]{
  extension: seed/extern/spw-workbench/extensions/vscode-spw/src/extension.ts
  roots: seed/extern/spw-workbench/extensions/vscode-spw/src/roots.ts
  semantics: seed/extern/spw-workbench/extensions/vscode-spw/src/semantics.ts
}

^care[history]{
  files: [
    seed/extern/spw-workbench/docs/design/md/history.md,
    seed/extern/spw-workbench/docs/archive/status/md/vim-implementation-complete.md
  ]
}

^care[plugin-architecture]{
  control_plane: [
    .spw/surfaces/index.spw,
    .spw/surfaces/plugin-protocol.spw,
    .spw/substrates/structural.spw,
    .spw/runtime/precipitates.spw
  ]
  runtime_surfaces: [
    src/core/runtime/js/spwlang-parser.js,
    seed/site/enhancements/workbench-parser-adapter.js
  ]
}

^care[cross-repo]{
  downstream: "https://github.com/spwashi/spwashi.work"
  policy: "reference-not-mirror"
  projection: "consume indices, runtime contracts, and release semantics from spwashi.click"
}

!ask[feature-gap]{
  input: "project-goal"
  process: "compare goal against ^feature[] and ^semantics[] entries"
  output: "ranked add-next-feature list with source pointers"
}
