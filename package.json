{
  "name": "spwashi-click",
  "version": "1.0.0",
  "description": "spwashi.click static site with vanilla web components",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "node ./scripts/lint.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:e2e": "node --test tests/e2e/*.test.js",
    "test": "npm run test:unit && npm run test:e2e",
    "check": "npm run lint && npm run test",
    "build": "node ./scripts/build-static.js",
    "export:assets": "node ./scripts/export-assets.js"
  },
  "exports": {
    ".": "./src/runtime/index.js",
    "./runtime": "./src/runtime/index.js",
    "./contracts/spw-index": "./spw.index.json",
    "./contracts/spw-index-spw": "./spw.index.spw",
    "./contracts/workspace": "./.spw/workspace.spw",
    "./assets/manifest": "./assets.manifest.json",
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./styles/base.css": "./src/styles/base.css",
    "./styles/layout.css": "./src/styles/layout.css",
    "./styles/components.css": "./src/styles/components.css",
    "./sw": "./sw.js"
  },
  "engines": {
    "node": ">=20"
  }
}
